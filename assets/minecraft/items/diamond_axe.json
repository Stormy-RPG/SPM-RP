{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:component",
    "component": "minecraft:custom_name",
    "cases": [
      {
        "when": ["Tomahawk", "Томагавк"],
        "model": {
          "type": "minecraft:model",
          "model": "mirrp:item/other/tomahawk"
        }
      },
      {
				"when": ["Packed Axe", "Подарочный топор"],
				"model": {
          "type": "minecraft:model", 
          "model": "mrp:item/presents/packed_axe"
        }
			},
			{
				"when": ["Chainsaw Reaper", "Бензопила \"Жнец\""],
				"model": {
					"type": "minecraft:model",
					"model": "ironworks:tools/chainsaw_reaper"
				}
			},
			{
				"when": ["Disc Saw", "Дисковая пила"],
				"model": {
					"type": "minecraft:model",
					"model": "ironworks:tools/disc_saw"
				}
			},
			{
				"when": ["Simple Sledgehammer", "Простая кувалда"],
				"model": {
					"type": "minecraft:model",
					"model": "ironworks:tools/simple_sledgehammer"
				}
			}
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/diamond_axe"
    }
  }
}